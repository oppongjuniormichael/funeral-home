# .env.local.example
# Copy this file to .env.local and fill in your actual credentials
# NEVER commit .env.local to git

# EmailJS Configuration
# Get these from https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here

# Booking Templates
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=booking_admin_notification
NEXT_PUBLIC_EMAILJS_CONFIRMATION_TEMPLATE_ID=booking_customer_confirmation

# Contact Templates
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=contact_admin_notification
NEXT_PUBLIC_EMAILJS_CONTACT_CONFIRMATION_TEMPLATE_ID=contact_customer_confirmation

# Hubtel SMS Configuration
# Get these from https://www.hubtel.com/
NEXT_PUBLIC_HUBTEL_API_KEY=your_hubtel_api_key_here
NEXT_PUBLIC_HUBTEL_CLIENT_ID=your_hubtel_client_id_here
NEXT_PUBLIC_HUBTEL_CLIENT_SECRET=your_hubtel_client_secret_here
NEXT_PUBLIC_HUBTEL_SENDER_ID=DonkorAndSons

# Admin Contact Information
NEXT_PUBLIC_ADMIN_EMAIL=demi@example.com
NEXT_PUBLIC_ADMIN_PHONE=+233XXXXXXXXXX
